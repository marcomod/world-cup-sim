{
  "name": "world-cup-sim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "ratings:generate": "node --no-warnings --experimental-strip-types scripts/ratings-pipeline/generateRatings.ts",
    "historical:validate": "node --no-warnings --experimental-strip-types scripts/historical-pipeline/validateHistoricalDataset.ts",
    "historical:test": "vitest run tests/data/historicalPipeline.test.ts tests/data/historicalKaggleAdapter.test.ts tests/calibration/sequentialElo.test.ts tests/calibration/evaluation.test.ts tests/calibration/divisorComparison.test.ts tests/calibration/holdoutEvaluation.test.ts tests/calibration/uncertaintyAnalysis.test.ts",
    "calibration:reconstruct-elo": "node --no-warnings --experimental-strip-types scripts/calibration/reconstructHistoricalElo.ts",
    "calibration:evaluate-elo": "node --no-warnings --experimental-strip-types scripts/calibration/evaluateHistoricalElo.ts",
    "calibration:compare-divisors": "node --no-warnings --experimental-strip-types scripts/calibration/compareHistoricalEloDivisors.ts",
    "calibration:evaluate-holdout": "node --no-warnings --experimental-strip-types scripts/calibration/evaluateHistoricalEloHoldout.ts",
    "calibration:analyze-uncertainty": "node --no-warnings --experimental-strip-types scripts/calibration/analyzeHistoricalEloUncertainty.ts",
    "tournament2026:build-official-snapshot": "node --no-warnings --loader ./scripts/tournament-2026/tsPathAliasLoader.mjs --experimental-strip-types scripts/tournament-2026/buildOfficialSnapshot.ts",
    "tournament2026:verify-official-snapshot": "node --no-warnings --loader ./scripts/tournament-2026/tsPathAliasLoader.mjs --experimental-strip-types scripts/tournament-2026/verifyOfficialSnapshot.ts",
    "tournament2026:diff-snapshots": "node --no-warnings --loader ./scripts/tournament-2026/tsPathAliasLoader.mjs --experimental-strip-types scripts/tournament-2026/diffSnapshots.ts",
    "tournament2026:build-knockout-ratings": "node --no-warnings --loader ./scripts/tournament-2026/tsPathAliasLoader.mjs --experimental-strip-types scripts/tournament-2026/buildKnockoutRatings.ts"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
